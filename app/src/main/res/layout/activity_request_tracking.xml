<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="24dp">

    <!-- Header -->
    <ImageView
        android:id="@+id/iv_back"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="16dp"
        android:padding="4dp"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:text="Request Tracking"
        android:textColor="@color/text_dark"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/iv_back"
        app:layout_constraintStart_toEndOf="@id/iv_back"
        app:layout_constraintTop_toTopOf="@id/iv_back" />

    <!-- Live Tracking Card -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/card_live_tracking"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_card_light_blue"
        android:padding="24dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title">

        <ImageView
            android:id="@+id/iv_loc_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_location"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_live_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Live Tracking"
            android:textColor="@color/text_dark"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/iv_loc_icon"
            app:layout_constraintStart_toEndOf="@id/iv_loc_icon"
            app:layout_constraintTop_toTopOf="@id/iv_loc_icon" />

        <TextView
            android:id="@+id/tv_live_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Donor is on the way"
            android:textColor="@color/text_gray"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@id/tv_live_label"
            app:layout_constraintTop_toBottomOf="@id/tv_live_label" />

        <TextView
            android:id="@+id/tv_distance_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Distance"
            android:textColor="@color/text_gray"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_live_status" />

        <TextView
            android:id="@+id/tv_distance_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="2.5 km"
            android:textColor="@color/text_dark"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_distance_label" />

        <TextView
            android:id="@+id/tv_eta_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ETA"
            android:textColor="@color/text_gray"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_distance_label" />

        <TextView
            android:id="@+id/tv_eta_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="15 min"
            android:textColor="@color/text_dark"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_eta_label" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_view_live_map"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_button_blue_small"
            android:text="View Live Map"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/tv_distance_value" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Stepper Status Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/stepper_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/card_live_tracking">

        <!-- Step 1: Requested -->
        <View
            android:id="@+id/step1_circle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_green_circle_solid"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_check"
            app:layout_constraintBottom_toBottomOf="@id/step1_circle"
            app:layout_constraintEnd_toEndOf="@id/step1_circle"
            app:layout_constraintStart_toStartOf="@id/step1_circle"
            app:layout_constraintTop_toTopOf="@id/step1_circle"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tv_step1_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Requested"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="@id/step1_circle"
            app:layout_constraintStart_toEndOf="@id/step1_circle"
            app:layout_constraintTop_toTopOf="@id/step1_circle" />

        <View
            android:id="@+id/line1"
            android:layout_width="3dp"
            android:layout_height="40dp"
            android:background="@color/success_green"
            app:layout_constraintEnd_toEndOf="@id/step1_circle"
            app:layout_constraintStart_toStartOf="@id/step1_circle"
            app:layout_constraintTop_toBottomOf="@id/step1_circle" />

        <!-- Step 2: Matched -->
        <View
            android:id="@+id/step2_circle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_green_circle_solid"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/line1" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_check"
            app:layout_constraintBottom_toBottomOf="@id/step2_circle"
            app:layout_constraintEnd_toEndOf="@id/step2_circle"
            app:layout_constraintStart_toStartOf="@id/step2_circle"
            app:layout_constraintTop_toTopOf="@id/step2_circle"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tv_step2_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Matched"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="@id/step2_circle"
            app:layout_constraintStart_toEndOf="@id/step2_circle"
            app:layout_constraintTop_toTopOf="@id/step2_circle" />

        <View
            android:id="@+id/line2"
            android:layout_width="3dp"
            android:layout_height="40dp"
            android:background="@color/success_green"
            app:layout_constraintEnd_toEndOf="@id/step2_circle"
            app:layout_constraintStart_toStartOf="@id/step2_circle"
            app:layout_constraintTop_toBottomOf="@id/step2_circle" />

        <!-- Step 3: In Progress -->
        <View
            android:id="@+id/step3_circle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_red_circle_solid"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/line2" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/step3_circle"
            app:layout_constraintEnd_toEndOf="@id/step3_circle"
            app:layout_constraintStart_toStartOf="@id/step3_circle"
            app:layout_constraintTop_toTopOf="@id/step3_circle" />

        <TextView
            android:id="@+id/tv_step3_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="In Progress"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            app:layout_constraintStart_toEndOf="@id/step3_circle"
            app:layout_constraintTop_toTopOf="@id/step3_circle" />

        <TextView
            android:id="@+id/tv_step3_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Donor on the way"
            android:textColor="@color/text_gray"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@id/tv_step3_label"
            app:layout_constraintTop_toBottomOf="@id/tv_step3_label" />

        <View
            android:id="@+id/line3"
            android:layout_width="3dp"
            android:layout_height="40dp"
            android:background="#E2E8F0"
            app:layout_constraintEnd_toEndOf="@id/step3_circle"
            app:layout_constraintStart_toStartOf="@id/step3_circle"
            app:layout_constraintTop_toBottomOf="@id/step3_circle" />

        <!-- Step 4: Completed -->
        <View
            android:id="@+id/step4_circle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_grey_circle_solid"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/line3" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4"
            android:textColor="@color/text_gray"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/step4_circle"
            app:layout_constraintEnd_toEndOf="@id/step4_circle"
            app:layout_constraintStart_toStartOf="@id/step4_circle"
            app:layout_constraintTop_toTopOf="@id/step4_circle" />

        <TextView
            android:id="@+id/tv_step4_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Completed"
            android:textColor="@color/text_light"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="@id/step4_circle"
            app:layout_constraintStart_toEndOf="@id/step4_circle"
            app:layout_constraintTop_toTopOf="@id/step4_circle" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Buttons Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_contact_donor"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_button_solid"
            android:text="Contact Donor"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_cancel_request"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_button_outline"
            android:text="Cancel Request"
            android:textAllCaps="false"
            android:textColor="@color/bright_red"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
