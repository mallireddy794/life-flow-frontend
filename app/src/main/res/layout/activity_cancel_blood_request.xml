<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".CancelBloodRequestActivity">

    <!-- Header -->
    <ImageView
        android:id="@+id/iv_back"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:padding="4dp"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/text_dark" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:text="Cancel Request"
        android:textColor="@color/text_dark"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/iv_back"
        app:layout_constraintStart_toEndOf="@id/iv_back"
        app:layout_constraintTop_toTopOf="@id/iv_back" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Request Summary Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_light_pink"
                android:elevation="2dp"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/iv_header_bg"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/bg_icon_circle_pink"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_blood_drop"
                    app:layout_constraintBottom_toBottomOf="@id/iv_header_bg"
                    app:layout_constraintEnd_toEndOf="@id/iv_header_bg"
                    app:layout_constraintStart_toStartOf="@id/iv_header_bg"
                    app:layout_constraintTop_toTopOf="@id/iv_header_bg"
                    app:tint="@color/blood_red" />

                <TextView
                    android:id="@+id/tv_request_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Request #BR-2024-001"
                    android:textColor="@color/text_dark"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/iv_header_bg"
                    app:layout_constraintTop_toTopOf="@id/iv_header_bg" />

                <TextView
                    android:id="@+id/tv_request_details"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="O+ Blood Type • 2 Units"
                    android:textColor="@color/text_gray"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="@id/tv_request_id"
                    app:layout_constraintTop_toBottomOf="@id/tv_request_id" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Why are you cancelling?"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Please select the most relevant reason"
                android:textColor="@color/text_gray"
                android:textSize="14sp" />

            <RadioGroup
                android:id="@+id/rg_reasons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">

                <RadioButton
                    android:id="@+id/rb_reason1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_radio_button"
                    android:button="@null"
                    android:checked="false"
                    android:padding="16dp"
                    android:text="Donor found elsewhere"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp" />

                <RadioButton
                    android:id="@+id/rb_reason2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_radio_button"
                    android:button="@null"
                    android:padding="16dp"
                    android:text="Treatment postponed"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp" />

                <RadioButton
                    android:id="@+id/rb_reason3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_radio_button"
                    android:button="@null"
                    android:padding="16dp"
                    android:text="No longer required"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp" />

                <RadioButton
                    android:id="@+id/rb_reason4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_radio_button"
                    android:button="@null"
                    android:padding="16dp"
                    android:text="Incorrect request details"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp" />

                <RadioButton
                    android:id="@+id/rb_reason5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_radio_button"
                    android:button="@null"
                    android:padding="16dp"
                    android:text="Others"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp" />
            </RadioGroup>

            <EditText
                android:id="@+id/et_other_reason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:gravity="top"
                android:hint="Type your reason here..."
                android:minHeight="120dp"
                android:padding="16dp"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_card_light_yellow"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="1dp"
                    android:src="@drawable/ic_exclamation_circle"
                    app:tint="#854D0E" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Note: Frequent cancellations may affect your priority for future emergency requests."
                    android:textColor="#854D0E"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_confirm_cancel"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_margin="24dp"
        android:background="@drawable/bg_button_solid"
        android:elevation="4dp"
        android:text="Confirm Cancellation"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
