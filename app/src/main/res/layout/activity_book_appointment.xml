<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="24dp"
    tools:context=".BookAppointmentActivity">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Book Appointment"
            android:textColor="@color/text_dark"
            android:textSize="22sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Select Date Section -->
    <TextView
        android:id="@+id/tv_select_date_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="Select Date"
        android:textColor="@color/text_gray"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header" />

    <EditText
        android:id="@+id/et_appointment_date"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_input_field"
        android:clickable="true"
        android:focusable="false"
        android:hint="DD/MM/YYYY"
        android:paddingHorizontal="16dp"
        android:inputType="none"
        android:textColor="@color/text_dark"
        app:layout_constraintTop_toBottomOf="@id/tv_select_date_label" />

    <!-- Select Time Slot Section -->
    <TextView
        android:id="@+id/tv_select_time_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Select Time Slot"
        android:textColor="@color/text_gray"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_appointment_date" />

    <!-- Time Slots Grid -->
    <GridLayout
        android:id="@+id/grid_time_slots"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:columnCount="3"
        android:alignmentMode="alignMargins"
        android:columnOrderPreserved="false"
        app:layout_constraintTop_toBottomOf="@id/tv_select_time_label">

        <TextView
            android:id="@+id/slot_09am"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@drawable/bg_time_slot"
            android:gravity="center"
            android:text="09:00 AM"
            android:textColor="@color/text_dark" />

        <TextView
            android:id="@+id/slot_10am"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@drawable/bg_time_slot"
            android:gravity="center"
            android:text="10:00 AM"
            android:textColor="@color/text_dark" />

        <TextView
            android:id="@+id/slot_11am"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@drawable/bg_time_slot"
            android:gravity="center"
            android:text="11:00 AM"
            android:textColor="@color/text_dark" />

        <TextView
            android:id="@+id/slot_02pm"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@drawable/bg_time_slot"
            android:gravity="center"
            android:text="02:00 PM"
            android:textColor="@color/text_dark" />

        <TextView
            android:id="@+id/slot_03pm"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@drawable/bg_time_slot"
            android:gravity="center"
            android:text="03:00 PM"
            android:textColor="@color/text_dark" />

        <TextView
            android:id="@+id/slot_04pm"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@drawable/bg_time_slot"
            android:gravity="center"
            android:text="04:00 PM"
            android:textColor="@color/text_dark" />

    </GridLayout>

    <!-- Confirm Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_confirm_appointment"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/bg_button_solid"
        android:text="Confirm Appointment"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/grid_time_slots" />

</androidx.constraintlayout.widget.ConstraintLayout>
